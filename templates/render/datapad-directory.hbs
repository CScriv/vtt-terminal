{{!--
  render/datapad-directory.hbs — list of datapads (collection "datapads").
  Generated from the collection; each row navigates to its detail.
--}}
{{#if screen.prompt}}
  <p class="term-prompt">&gt; {{screen.prompt}}</p>
{{/if}}

{{#each groups}}
  {{#if this.rows.length}}
    <table class="mission-index">
      <thead><tr><th>Datapad</th><th>Source</th><th>Recovered</th></tr></thead>
      <tbody>
        {{#each this.rows}}
          <tr class="nav-card" data-action="navigate" data-target="{{this.target}}">
            <td><span class="roster-name">{{this.title}}</span></td>
            <td>{{this.source}}</td>
            <td>{{this.date}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p class="mission-empty">— no datapads recovered —</p>
  {{/if}}
{{/each}}
