{{!--
  render/inbox.hbs — per-viewer inbox, as a list of THREADS.
  `inbox` (from #prepInbox): { isGM, hasBinding, canCompose, screenId,
    threads:[{ threadId, subject, participantLine, count, time, unread,
    screenId }], unreadCount }.
  A row navigates to inbox/thread/<threadId>; the thread screen shows the
  full conversation and the reply control. No inline expand here.
--}}
{{#if screen.prompt}}
  <p class="term-prompt">&gt; {{screen.prompt}}</p>
{{/if}}

{{#unless inbox.hasBinding}}
  <p class="inbox-empty">No mailbox is associated with your account. (Ask the GM to bind your character.)</p>
{{/unless}}

{{#if inbox.hasBinding}}
  <p class="term-prompt">&gt; INBOX{{#if inbox.unreadCount}} <span class="inbox-unread-count">({{inbox.unreadCount}} unread)</span>{{/if}}</p>

  {{#if inbox.filterCrew}}
    <div class="inbox-filter">
      <label class="inbox-filter-label">VIEWING AS</label>
      <select class="inbox-filter-select">
        <option value="">— ALL MAILBOXES —</option>
        {{#each inbox.filterCrew}}
          <option value="{{this.id}}"{{#if this.selected}} selected{{/if}}>{{this.name}}</option>
        {{/each}}
      </select>
    </div>
  {{/if}}

  {{#if inbox.threads.length}}
    <div class="thread-list">
      {{#each inbox.threads}}
        <div class="thread-row{{#if this.unread}} thread-unread{{/if}}" data-action="navigate" data-target="{{this.screenId}}/thread/{{this.threadId}}">
          {{#if this.unread}}<span class="thread-dot">●</span>{{else}}<span class="thread-dot thread-dot-read">·</span>{{/if}}
          <span class="thread-row-subject">{{this.subject}}</span>
          <span class="thread-row-participants">{{this.participantLine}}</span>
          {{#if this.count}}<span class="thread-row-count">{{this.count}}</span>{{/if}}
          <span class="thread-row-time">{{this.time}}</span>
          {{#unless ../inbox.isGM}}<span class="thread-del" data-action="deleteThread" data-thread-id="{{this.threadId}}" data-screen-id="{{this.screenId}}" title="Move to trash">✕</span>{{/unless}}
        </div>
      {{/each}}
    </div>
  {{else}}
    <p class="inbox-empty">— no messages —</p>
  {{/if}}

  {{#if inbox.canCompose}}
    <p class="term-prompt"><a data-action="composeMessage" data-screen-id="{{inbox.screenId}}">&gt; [ COMPOSE MESSAGE ]</a></p>
  {{/if}}

  {{#if inbox.hasTrash}}
    <details class="feed-archive inbox-trash">
      <summary class="term-prompt">&gt; TRASH ({{inbox.trashCount}})</summary>
      <div class="feed-archive-body">
        <div class="thread-list">
          {{#each inbox.trashed}}
            <div class="thread-row thread-trashed" data-action="navigate" data-target="{{this.screenId}}/thread/{{this.threadId}}">
              <span class="thread-dot thread-dot-read">·</span>
              <span class="thread-row-subject">{{this.subject}}</span>
              <span class="thread-row-participants">{{this.participantLine}}</span>
              {{#if this.count}}<span class="thread-row-count">{{this.count}}</span>{{/if}}
              <span class="thread-row-time">{{this.time}}</span>
              {{#unless ../inbox.isGM}}<span class="thread-del thread-restore" data-action="restoreThread" data-thread-id="{{this.threadId}}" data-screen-id="{{this.screenId}}" title="Restore to inbox">&#8631;</span>{{/unless}}
            </div>
          {{/each}}
        </div>
      </div>
    </details>
  {{/if}}
{{/if}}
