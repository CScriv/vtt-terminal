{{!--
  render/feed.hbs — crew feed.
  Posts come pre-sorted/partitioned from #prepFeed:
    feed.recent   — visible posts (pinned first, then newest-first)
    feed.archived — posts older than feedArchiveDays (pinned never here)
  Each post block is rendered via the terminalFeedPost partial. Author /
  reply-author names link to dossiers when authorId is present. official ->
  Notice styling; pinned -> pinned styling + float to top.

  Owner menu (···) per post/reply carries Edit / Pin / Delete gated by the
  canEdit / canPin / canDelete flags from #prepFeed.
--}}
{{#if screen.prompt}}
  <p class="term-prompt">&gt; {{screen.prompt}}</p>
{{/if}}

<p class="term-prompt feed-post-trigger"><a data-action="composePost" data-screen-id="{{feed.screenId}}">&gt; [ POST TO FEED ]</a></p>

{{#each feed.recent}}
  {{> terminalFeedPost this}}
{{/each}}

{{#if feed.hasArchive}}
  <details class="feed-archive">
    <summary class="term-prompt">&gt; ARCHIVE ({{feed.archiveCount}})</summary>
    <div class="feed-archive-body">
      {{#each feed.archived}}
        {{> terminalFeedPost this}}
      {{/each}}
    </div>
  </details>
{{/if}}
