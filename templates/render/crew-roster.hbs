{{!--
  render/crew-roster.hbs — generated roster index.
  Receives `groups`: ordered array of
    { name, members: [...], subgroups: [{ name, members: [...] }] }
  built in JS from the crew collection. Each member row navigates to
  its dossier via data-target="<collection>/<id>".
--}}
{{#if screen.prompt}}
  <p class="term-prompt">&gt; {{screen.prompt}}</p>
{{/if}}

{{#each groups}}
  <details class="term-section">
    <summary class="term-prompt">&gt; {{this.name}}</summary>

    {{#if this.members.length}}
      <table class="mission-index">
        <tbody>
          {{#each this.members}}
            <tr class="nav-card" data-action="navigate" data-target="{{this.collection}}/{{this.id}}">
              <td><span class="roster-name">{{this.name}}</span></td>
              <td>{{this.role}}</td>
              <td>{{> terminalStatusFlag status=this.status}}</td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{/if}}

    {{#each this.subgroups}}
      <details class="term-subsection" open>
        <summary class="subsection-label">{{this.name}}</summary>
        <table class="mission-index">
          <tbody>
            {{#each this.members}}
              <tr class="nav-card" data-action="navigate" data-target="{{this.collection}}/{{this.id}}">
                <td><span class="roster-name">{{this.name}}</span></td>
                <td>{{this.role}}</td>
                <td>{{> terminalStatusFlag status=this.status}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </details>
    {{/each}}

  </details>
  <hr>
{{/each}}
