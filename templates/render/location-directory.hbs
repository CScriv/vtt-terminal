{{!--
  render/location-directory.hbs — top-level galaxy directory.
  Lists regions (tier "region"); each navigates to its location screen.
--}}
{{#if screen.prompt}}
  <p class="term-prompt">&gt; {{screen.prompt}}</p>
{{/if}}

{{#each groups}}
  {{#if this.rows.length}}
    <table class="mission-index">
      <thead><tr><th>Region</th><th>Overview</th></tr></thead>
      <tbody>
        {{#each this.rows}}
          <tr class="nav-card" data-action="navigate" data-target="{{this.target}}">
            <td><span class="roster-name">{{this.name}}</span></td>
            <td>{{this.description}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p class="mission-empty">— no regions charted —</p>
  {{/if}}
{{/each}}
